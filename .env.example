# Sarvam AI Configuration
# Get your API key from https://sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Anthropic API Key (for Claude)
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override Sarvam Chat Model
# Default: sarvam-30b
# SARVAM_CHAT_MODEL=sarvam-30b-instruct

# Optional: Override TTS Speaker
# Default: vijay (Tamil male voice)
# Options: vijay (male), priya (female), others available
# SARVAM_TTS_SPEAKER=vijay

# Optional: Development/Production Flags
# NODE_ENV=development
